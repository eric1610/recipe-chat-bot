# Development-only placeholders. Never copy production values into a local environment file.
# Generate with: openssl rand -hex 32
AUTH_SECRET=

# Isolated non-production Neon pooled connection string using a least-privileged runtime role.
DATABASE_URL=

# Server-only OpenRouter key. Use a separate non-production key for local development.
OPENROUTER_API_KEY=

# Comma-separated account emails that bypass only the per-user AI cap.
# Keep production account identifiers in the hosting environment, not this file.
AI_DAILY_CAP_EXEMPT_EMAILS=

# Separate non-production OAuth clients only.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# GitHub OAuth app.
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
