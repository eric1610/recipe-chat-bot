# Development-only placeholders. Never copy production values into a local environment file.
# Generate with: openssl rand -hex 32
AUTH_SECRET=

# Isolated non-production Neon pooled connection string using a least-privileged runtime role.
DATABASE_URL=

# Separate non-production OAuth clients only.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# GitHub OAuth app.
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
